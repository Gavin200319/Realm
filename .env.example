# ================================================================
# Reality Merge v1 — environment variables
#
# I can't generate real Supabase credentials for you — they're tied
# to a project you create yourself. Steps:
#
# 1. Go to https://supabase.com/dashboard and create a new project.
# 2. Once it's provisioned, go to Project Settings -> API.
# 3. Copy "Project URL" into SUPABASE_URL below.
# 4. Copy "anon public" key into SUPABASE_ANON_KEY below.
# 5. Rename this file to `.env` (do NOT commit the real .env to git —
#    it's already in .gitignore below).
# 6. Run schema.sql (in /supabase) in the Supabase SQL editor to
#    create the tables, policies, and functions.
# ================================================================

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Mapbox — used for map tiles. Get a free token at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_TOKEN

# Default unlock radius (meters) used by the client as a fallback if a
# drop doesn't specify one. Should match the default in schema.sql.
DEFAULT_UNLOCK_RADIUS_M=50

# Optional — enables a last-resort AI-generated illustration for
# Updates-tab stories that have no image anywhere (not in the RSS
# feed, not on the publisher's own page). Leave blank to disable —
# those cards will simply show no image, same as before this existed.
# Capped at 8 generations per app session regardless of how many
# stories are missing an image. Get a key at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
